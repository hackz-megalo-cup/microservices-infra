DEVENV_ROOT=$(pwd)
watch_file devenv.nix
watch_file treefmt.nix
watch_file nixidy/env/local.nix
watch_file nixidy/env/local/*.nix
if ! use flake . --impure --override-input devenv-root "file+file://"<(printf %s "$PWD")
then
  echo "devenv could not be built. The devenv environment was not loaded. Make sure you have devenv running." >&2
fi

# Override DEVENV_ROOT after flake evaluation to avoid nix store cache collision
# between repos with identical devenv-root narHash
DEVENV_ROOT="$(pwd)"

DEVENV_ROOT=$(pwd)
watch_file devenv.nix
watch_file treefmt-programs.nix
watch_file nixidy/env/local.nix
watch_file nixidy/env/local/*.nix

# Write $PWD to a persistent file instead of using process substitution.
# Process substitution (<(printf %s "$PWD")) creates a transient /dev/fd/N,
# which can cause Nix eval cache collisions between repos with similar flake
# configurations (e.g. microservices-app vs microservices-infra).
# A persistent file with a repo-specific absolute URL prevents this.
printf '%s' "$PWD" > .devenv-root

if ! use flake . --impure --override-input devenv-root "file+file://$PWD/.devenv-root"
then
  echo "devenv could not be built. The devenv environment was not loaded. Make sure you have devenv running." >&2
fi
